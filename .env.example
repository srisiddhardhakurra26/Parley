# Copy to .env — it's loaded automatically. Without a key, Parley runs on the
# deterministic mock provider (the full pipeline works, just with scripted turns).

# Groq: free, fast, OpenAI-compatible. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Any Groq model id — see https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# — OR — any other OpenAI-compatible free tier (Together, OpenRouter, Cerebras,
# a local Ollama, …). If LLM_API_KEY is set it takes precedence over GROQ_*.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=
# LLM_MODEL=llama-3.3-70b-versatile

PORT=4505
